{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "启动后端开发服务器",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "启动全栈开发环境",
      "configurations": ["启动前端开发服务器", "启动后端开发服务器"],
      "stopAll": true
    }
  ]
}